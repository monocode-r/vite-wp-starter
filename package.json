{
  "name": "wp-theme-vite",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "node scripts/generate-wp-env.mjs && wp-env start && open http://localhost:8888 && vite",
    "build": "vite build && node scripts/optimize-images.mjs",
    "build:images-both": "vite build && IMAGE_OUTPUT_MODE=both node scripts/optimize-images.mjs",
    "build:images-raster": "vite build && IMAGE_OUTPUT_MODE=raster-only node scripts/optimize-images.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "format": "prettier --write 'src/**/*.{scss,js}' '**/*.php'",
    "lint:js": "eslint src/js",
    "lint:css": "stylelint 'src/sass/**/*.scss'",
    "lint": "eslint src/js && stylelint 'src/sass/**/*.scss'",
    "lint:fix": "eslint src/js --fix && stylelint 'src/sass/**/*.scss' --fix",
    "stop": "wp-env stop",
    "wp:destroy": "wp-env destroy",
    "wp:cli": "wp-env run cli wp",
    "wp:logs": "wp-env logs"
  },
  "browserslist": [
    "last 2 versions",
    "> 5%",
    "iOS >= 12",
    "Android >= 8",
    "not IE 11",
    "not IE_Mob 11"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@wordpress/env": "^11.2.0",
    "autoprefixer": "^10.4.20",
    "css-declaration-sorter": "^7.2.0",
    "eslint": "^10.2.0",
    "fast-glob": "^3.3.3",
    "globals": "^17.5.0",
    "imagemin": "^9.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-svgo": "^10.0.1",
    "imagemin-webp": "^8.0.0",
    "postcss": "^8.5.1",
    "postcss-combine-media-query": "^2.0.0",
    "postcss-preset-env": "^10.1.3",
    "prettier": "^3.8.1",
    "sass": "^1.83.4",
    "stylelint": "^17.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^6.0.11",
    "vite-plugin-sass-glob-import": "^6.0.3",
    "vite-plugin-static-copy": "^2.2.0"
  }
}
